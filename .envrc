# direnv config for local Podplane cluster dev — https://direnv.net
# Scope `podplane local start`/`login` kube state to this repo instead of
# writing "local"/"local-<id>" contexts into your real ~/.kube/config.
#
# NOTE: kubectl only writes to the *first* KUBECONFIG path if it already
# exists; if it's missing it silently falls through and writes to the next
# path instead (i.e. your real kubeconfig). Always `touch` it first.
mkdir -p .kube
touch .kube/config
export KUBECONFIG="$PWD/.kube/config:$HOME/.kube/config"

# Put ./bin (make build output) on PATH so `podplane` works without ./bin/ prefix.
PATH_add bin
